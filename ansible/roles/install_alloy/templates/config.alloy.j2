logging {
  level  = "info"
  format = "logfmt"
}

////////////////////////////////////////////////////////////////////////////////
// HOST METRICS
////////////////////////////////////////////////////////////////////////////////

prometheus.exporter.unix "node" {
  include_exporter_metrics = true

  disable_collectors = [
    "ipvs",
    "btrfs",
    "infiniband",
    "xfs",
    "zfs",
  ]

  filesystem {
    fs_types_exclude = "^(autofs|binfmt_misc|bpf|cgroup2?|configfs|debugfs|devpts|devtmpfs|fusectl|hugetlbfs|iso9660|mqueue|nsfs|overlay|proc|procfs|pstore|securityfs|selinuxfs|squashfs|sysfs|tracefs|tmpfs)$"

    mount_points_exclude = "^/(dev|proc|run/containerd/.+|sys|var/lib/docker/.+)($|/)"
  }

  netclass {
    ignored_devices = "^(veth.*|cali.*|flannel.*|docker.*|br-.*)$"
  }

  netdev {
    device_exclude = "^(veth.*|cali.*|flannel.*|docker.*|br-.*)$"
  }
}

////////////////////////////////////////////////////////////////////////////////
// PROCESS METRICS
////////////////////////////////////////////////////////////////////////////////

prometheus.exporter.process "processes" {
  matcher {
    name    = "{{ '{{.Comm}}' }}"
    cmdline = [".+"]
  }
}

////////////////////////////////////////////////////////////////////////////////
// DOCKER METRICS
////////////////////////////////////////////////////////////////////////////////

prometheus.exporter.cadvisor "docker" {
  docker_host = "unix:///var/run/docker.sock"

  storage_duration = "5m"

  enabled_metrics = [
    "cpu",
    "disk",
    "diskIO",
    "memory",
    "network",
    "process",
    "tcp",
    "udp",
    "percpu",
    "sched",
  ]

  store_container_labels = true
}

////////////////////////////////////////////////////////////////////////////////
// ALLOY SELF METRICS
////////////////////////////////////////////////////////////////////////////////

prometheus.exporter.self "alloy" {
}

////////////////////////////////////////////////////////////////////////////////
// NODE SCRAPE
////////////////////////////////////////////////////////////////////////////////

prometheus.scrape "node" {
  targets = prometheus.exporter.unix.node.targets

  job_name = "node-exporter"

  scrape_interval = "15s"

  forward_to = [
    prometheus.remote_write.prom.receiver,
  ]
}

////////////////////////////////////////////////////////////////////////////////
// PROCESS SCRAPE
////////////////////////////////////////////////////////////////////////////////

prometheus.scrape "processes" {
  targets = prometheus.exporter.process.processes.targets

  job_name = "process-exporter"

  scrape_interval = "30s"

  forward_to = [
    prometheus.remote_write.prom.receiver,
  ]
}

////////////////////////////////////////////////////////////////////////////////
// CADVISOR SCRAPE
////////////////////////////////////////////////////////////////////////////////

prometheus.scrape "docker" {
  targets = prometheus.exporter.cadvisor.docker.targets

  job_name = "cadvisor"

  scrape_interval = "15s"

  forward_to = [
    prometheus.remote_write.prom.receiver,
  ]
}

////////////////////////////////////////////////////////////////////////////////
// ALLOY SCRAPE
////////////////////////////////////////////////////////////////////////////////

prometheus.scrape "alloy" {
  targets = prometheus.exporter.self.alloy.targets

  job_name = "alloy"

  scrape_interval = "15s"

  forward_to = [
    prometheus.remote_write.prom.receiver,
  ]
}

////////////////////////////////////////////////////////////////////////////////
// DOCKER DISCOVERY
////////////////////////////////////////////////////////////////////////////////

discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

////////////////////////////////////////////////////////////////////////////////
// DOCKER LOG RELABELING
////////////////////////////////////////////////////////////////////////////////

discovery.relabel "docker_logs" {
  targets = discovery.docker.containers.targets

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }

  rule {
    source_labels = ["__meta_docker_container_image"]
    target_label  = "image"
  }

  rule {
    target_label = "host"
    replacement  = constants.hostname
  }
}

////////////////////////////////////////////////////////////////////////////////
// DOCKER LOGS
////////////////////////////////////////////////////////////////////////////////

loki.source.docker "containers" {
  host    = "unix:///var/run/docker.sock"
  targets = discovery.docker.containers.targets

  relabel_rules = discovery.relabel.docker_logs.rules

  labels = {
    job = "docker",
  }

  forward_to = [
    loki.write.logs.receiver,
  ]
}

////////////////////////////////////////////////////////////////////////////////
// SYSTEMD JOURNAL
////////////////////////////////////////////////////////////////////////////////

loki.source.journal "journal" {
  labels = {
    job  = "systemd-journal",
    host = constants.hostname,
  }

  forward_to = [
    loki.write.logs.receiver,
  ]
}

////////////////////////////////////////////////////////////////////////////////
// PROMETHEUS REMOTE WRITE
////////////////////////////////////////////////////////////////////////////////

prometheus.remote_write "prom" {
  endpoint {
    url = "http://{{ install_alloy_prometheus_host }}:9090/api/v1/write"
  }

  external_labels = {
    hostname = constants.hostname,
  }
}

////////////////////////////////////////////////////////////////////////////////
// LOKI
////////////////////////////////////////////////////////////////////////////////

loki.write "logs" {
  endpoint {
    url = "http://{{ install_alloy_loki_host }}:3100/loki/api/v1/push"
  }

  external_labels = {
    hostname = constants.hostname,
  }
}